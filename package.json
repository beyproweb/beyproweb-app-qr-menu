{
  "name": "app-qr-menu",
  "private": true,
  "version": "1.0.1",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "doctor": "npx expo-doctor",
    "eas:build:development": "npx eas-cli build --profile development --platform all",
    "eas:build:preview": "npx eas-cli build --profile preview --platform all",
    "eas:build:production": "npx eas-cli build --profile production --platform all",
    "eas:submit:ios": "npx eas-cli submit --profile production --platform ios",
    "eas:submit:android": "npx eas-cli submit --profile production --platform android",
    "eas:update:preview": "npx eas-cli update --branch preview --message \"Preview OTA update\"",
    "eas:update:production": "npx eas-cli update --branch production --message \"Production OTA update\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-linking": "~8.0.11",
    "expo-splash-screen": "~31.0.13",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "babel-preset-expo": "~54.0.6"
  },
  "volta": {
    "node": "22.14.0"
  }
}
